{
  "expo": {
    "name": "Telegram Chat",
    "slug": "telegram-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "newArchEnabled": false,
    "android": {
      "package": "com.flashchat.telegramui",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "INTERNET"
      ]
    },
    "plugins": [
      [
        "react-native-webview",
        {
          "allowsInlineMediaPlayback": true
        }
      ]
    ]
  }
}
